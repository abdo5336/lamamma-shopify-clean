{%- comment -%}
  Renders a product card.
  Accepts:
  - product: {Object} Product Liquid object
  - show_badge: {Boolean} Show sold out / new badge
  - section_id: {String} The ID of the section that contains this card
{%- endcomment -%}

{%- liquid
  assign ratio = 1
  if product.featured_media
    assign ratio = product.featured_media.preview_image.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}

<article class="product-card{% if product.available == false %} product-card--sold-out{% endif %}">
  <a class="product-card__link" href="{{ product.url }}">
    <div class="product-card__media" style="padding-bottom: {{ 1 | divided_by: ratio | times: 100 }}%">
      {%- if product.featured_media -%}
        <img
          class="product-card__image"
          src="{{ product.featured_media | image_url: width: 600 }}"
          alt="{{ product.featured_media.alt | escape }}"
          width="{{ product.featured_media.width }}"
          height="{{ product.featured_media.height }}"
          loading="lazy"
        >
        {%- if product.media[1] != blank -%}
          <img
            class="product-card__image product-card__image--hover"
            src="{{ product.media[1] | image_url: width: 600 }}"
            alt="{{ product.media[1].alt | escape }}"
            width="{{ product.media[1].width }}"
            height="{{ product.media[1].height }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
      {%- endif -%}

      {%- if show_badge -%}
        {%- if product.available == false -%}
          <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
        {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
          <span class="product-card__badge product-card__badge--new">New</span>
        {%- elsif product.compare_at_price > product.price -%}
          <span class="product-card__badge product-card__badge--sale">Sale</span>
        {%- endif -%}
      {%- endif -%}

      <div class="product-card__actions">
        <a
          href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ 'Order: ' | append: product.title | append: ' - ' | append: shop.url | append: product.url | url_encode }}"
          class="product-card__whatsapp"
          target="_blank"
          rel="noopener"
          onclick="event.stopPropagation()"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Order
        </a>
      </div>
    </div>

    <div class="product-card__info">
      {%- if product.vendor != blank -%}
        <p class="product-card__vendor">{{ product.vendor }}</p>
      {%- endif -%}
      <h3 class="product-card__title">{{ product.title | escape }}</h3>
      <div class="product-card__price">
        {%- if product.compare_at_price > product.price -%}
          <s class="product-card__compare-price">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="product-card__sale-price">{{ product.price | money }}</span>
      </div>
    </div>
  </a>
</article>
