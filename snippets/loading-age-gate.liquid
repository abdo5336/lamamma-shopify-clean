<div id="lms-loader" class="lms-loader" aria-hidden="true">
  <div class="lms-loader__bg"></div>
  <div class="lms-loader__content">
    <div class="lms-loader__emblem">
      <svg class="lms-loader__crest" viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M100 10 L180 50 L180 140 C180 185 100 230 100 230 C100 230 20 185 20 140 L20 50 Z" stroke="#c9a84c" stroke-width="1.5" fill="none" opacity="0.4"/>
        <path d="M100 25 L165 58 L165 138 C165 178 100 218 100 218 C100 218 35 178 35 138 L35 58 Z" stroke="#c9a84c" stroke-width="0.8" fill="none" opacity="0.6"/>
        <text x="100" y="108" text-anchor="middle" font-family="Cormorant Garamond, serif" font-size="42" font-weight="500" fill="#c9a84c" letter-spacing="4">LMS</text>
        <text x="100" y="130" text-anchor="middle" font-family="Inter, sans-serif" font-size="7" font-weight="300" fill="#c9a84c" letter-spacing="8" opacity="0.7">SIGNATURE</text>
        <line x1="60" y1="118" x2="140" y2="118" stroke="#c9a84c" stroke-width="0.5" opacity="0.4"/>
        <polygon points="100,55 107,70 123,70 110,79 115,95 100,85 85,95 90,79 77,70 93,70" stroke="#c9a84c" stroke-width="0.8" fill="none" opacity="0.5"/>
      </svg>
    </div>

    <div class="lms-loader__brand">
      <p class="lms-loader__label">LA MAMMA'S SIGNATURE</p>
    </div>

    <div class="lms-loader__gate" id="lms-age-gate">
      <p class="lms-loader__gate-headline">Private Luxury Storefront</p>
      <p class="lms-loader__gate-sub">This experience is intended for adults 18 years of age and older.</p>
      <div class="lms-loader__gate-actions">
        <button class="lms-loader__btn lms-loader__btn--primary" id="lms-age-confirm" onclick="lmsConfirmAge()">
          <span>Enter the Signature Experience</span>
        </button>
        <a class="lms-loader__btn lms-loader__btn--ghost" href="https://www.google.com">
          <span>I am under 18</span>
        </a>
      </div>
      <p class="lms-loader__gate-note">By entering, you confirm you are 18+ and agree to our terms.</p>
    </div>
  </div>
</div>

<script>
  (function() {
    var STORAGE_KEY = 'lms_age_verified';
    var loader = document.getElementById('lms-loader');

    function lmsEnterSite() {
      if (loader) {
        loader.classList.add('lms-loader--exit');
        setTimeout(function() {
          loader.style.display = 'none';
          document.body.classList.remove('lms-loading');
        }, 1200);
      }
    }

    window.lmsConfirmAge = function() {
      try { sessionStorage.setItem(STORAGE_KEY, '1'); } catch(e) {}
      lmsEnterSite();
    };

    var verified = false;
    try { verified = sessionStorage.getItem(STORAGE_KEY) === '1'; } catch(e) {}

    if (verified) {
      setTimeout(lmsEnterSite, 600);
    } else {
      document.body.classList.add('lms-loading');
      setTimeout(function() {
        var gate = document.getElementById('lms-age-gate');
        if (gate) gate.classList.add('lms-loader__gate--visible');
      }, 1800);
    }
  })();
</script>
