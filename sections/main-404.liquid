<section class="error-page" id="error-page">
  <div class="container">
    <div class="error-page__inner">
      <p class="error-page__code">404</p>
      <h1 class="error-page__title">This page has left the collection.</h1>
      <p class="error-page__body">The page you are looking for doesn't exist or has been moved.</p>
      <div class="error-page__actions">
        <a class="btn btn--primary" href="{{ routes.root_url }}">Return Home</a>
        <a class="btn btn--outline" href="{{ routes.all_products_collection_url }}">Shop the Collection</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404 Error",
  "tag": "section",
  "class": "section-404"
}
{% endschema %}
