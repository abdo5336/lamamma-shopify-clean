<article class="page-content" id="page-{{ page.id }}">
  <div class="container page-content__container">
    <header class="page-content__header">
      <h1 class="page-content__title">{{ page.title }}</h1>
    </header>
    <div class="page-content__body rte">
      {{ page.content }}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "class": "section-main-page"
}
{% endschema %}
