<section class="reviews-section" id="reviews-{{ section.id }}">
  <div class="container">
    <div class="section-header section-header--centered">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="section-heading">{{ section.settings.heading | default: 'What Our Clients Say' | escape }}</h2>
      {%- if section.settings.average_rating > 0 -%}
        <div class="reviews-section__rating">
          <div class="reviews-section__stars" aria-label="{{ section.settings.average_rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="star{% if i <= section.settings.average_rating %} star--filled{% endif %}">★</span>
            {%- endfor -%}
          </div>
          <span class="reviews-section__count">{{ section.settings.review_count }} verified reviews</span>
        </div>
      {%- endif -%}
    </div>

    <div class="reviews-track" id="reviews-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars" aria-label="{{ block.settings.rating }} out of 5">
            {%- for i in (1..5) -%}
              <span class="star{% if i <= block.settings.rating %} star--filled{% endif %}">★</span>
            {%- endfor -%}
          </div>
          <blockquote class="review-card__quote">
            <p>{{ block.settings.review_text | escape }}</p>
          </blockquote>
          <div class="review-card__author">
            <p class="review-card__name">{{ block.settings.reviewer_name | escape }}</p>
            {%- if block.settings.reviewer_location != blank -%}
              <p class="review-card__location">{{ block.settings.reviewer_location | escape }}</p>
            {%- endif -%}
            {%- if block.settings.product_purchased != blank -%}
              <p class="review-card__product">Purchased: {{ block.settings.product_purchased | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "class": "section-reviews",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Client Testimonials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "range",
      "id": "average_rating",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 5,
      "label": "Average rating"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count display",
      "default": "200+"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Rating"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review",
          "default": "Absolutely premium quality. The ritual set arrived beautifully packaged — felt like unboxing a luxury item. Will order again."
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "K. Mansouri"
        },
        {
          "type": "text",
          "id": "reviewer_location",
          "label": "Location",
          "default": "Casablanca, Morocco"
        },
        {
          "type": "text",
          "id": "product_purchased",
          "label": "Product purchased",
          "default": "Black Signature Ritual Set"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "review_text": "Absolutely premium quality. The ritual set arrived beautifully packaged — felt like unboxing a luxury item.", "reviewer_name": "K. Mansouri", "reviewer_location": "Casablanca, Morocco", "product_purchased": "Black Signature Ritual Set" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Finally a brand that takes smoking accessories seriously. The tray is a piece of art on my desk.", "reviewer_name": "Y. Benali", "reviewer_location": "Paris, France", "product_purchased": "Premium Rolling Tray" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "The packaging alone is a statement. Gifted it to a close friend — he was speechless.", "reviewer_name": "R. El Fassi", "reviewer_location": "Dubai, UAE", "product_purchased": "Signature Gift Bundle" } }
      ]
    }
  ]
}
{% endschema %}
