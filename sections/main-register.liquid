<section class="customer-page" id="customer-register">
  <div class="container customer-page__container">
    <h1 class="customer-page__title">Create Account</h1>
    {%- form 'create_customer', class: 'customer-form' -%}
      {%- if form.errors -%}
        <div class="form-errors">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="form-group form-group--half">
        <label for="first-name">First Name</label>
        <input type="text" name="customer[first_name]" id="first-name" autocomplete="given-name">
      </div>
      <div class="form-group form-group--half">
        <label for="last-name">Last Name</label>
        <input type="text" name="customer[last_name]" id="last-name" autocomplete="family-name">
      </div>
      <div class="form-group">
        <label for="reg-email">Email</label>
        <input type="email" name="customer[email]" id="reg-email" autocomplete="email" required>
      </div>
      <div class="form-group">
        <label for="reg-password">Password</label>
        <input type="password" name="customer[password]" id="reg-password" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">Create Account</button>
      <p class="customer-form__links">
        <a href="{{ routes.account_login_url }}">Already have an account? Sign In</a>
      </p>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "tag": "section",
  "class": "section-customer-register"
}
{% endschema %}
