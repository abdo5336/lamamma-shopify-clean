<section class="bundles-highlight" id="bundles-{{ section.id }}">
  <div class="container">
    <div class="section-header section-header--centered">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="bundles-highlight__grid">
      {%- assign bundles_collection = collections[section.settings.collection] -%}
      {%- if bundles_collection != blank -%}
        {%- for product in bundles_collection.products limit: section.settings.product_limit -%}
          <div class="bundle-card {% if forloop.first %}bundle-card--featured{% endif %}">
            <a class="bundle-card__link" href="{{ product.url }}">
              <div class="bundle-card__media">
                {%- if product.featured_media -%}
                  <img
                    class="bundle-card__image"
                    src="{{ product.featured_media | image_url: width: 900 }}"
                    alt="{{ product.featured_media.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="900"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'bundle-card__placeholder' }}
                {%- endif -%}
                <div class="bundle-card__overlay">
                  <span class="bundle-card__cta">View Bundle</span>
                </div>
              </div>
              <div class="bundle-card__info">
                <div class="bundle-card__meta">
                  <p class="bundle-card__vendor">{{ product.vendor }}</p>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="bundle-card__save">Save {{ product.compare_at_price | minus: product.price | money }}</span>
                  {%- endif -%}
                </div>
                <h3 class="bundle-card__title">{{ product.title | escape }}</h3>
                <div class="bundle-card__price-row">
                  {%- if product.compare_at_price > product.price -%}
                    <s class="bundle-card__compare">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                  <span class="bundle-card__price">{{ product.price | money }}</span>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <div class="bundle-card {% if forloop.first %}bundle-card--featured{% endif %}">
            <div class="bundle-card__media bundle-card__media--placeholder">
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'bundle-card__placeholder' }}
            </div>
            <div class="bundle-card__info">
              <h3 class="bundle-card__title">{{ block.settings.title | default: 'Signature Bundle' | escape }}</h3>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="bundles-highlight__footer">
        <a class="btn btn--outline" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bundles Highlight",
  "tag": "section",
  "class": "section-bundles",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Signature Sets"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Ritual Bundles"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every object chosen with intention. Every set a statement."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Bundles collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "View All Bundles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Bundle title",
          "default": "Signature Bundle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundles Highlight"
    }
  ]
}
{% endschema %}
