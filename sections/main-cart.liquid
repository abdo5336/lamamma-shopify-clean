<section class="cart-page" id="cart-page">
  <div class="container">
    <h1 class="cart-page__title">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'cart-form' -%}
        <div class="cart-page__layout">
          <div class="cart-page__items">
            {%- for item in cart.items -%}
              <div class="cart-item" data-line="{{ forloop.index }}">
                <div class="cart-item__media">
                  <a href="{{ item.url }}">
                    <img
                      class="cart-item__image"
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | default: item.title | escape }}"
                      loading="lazy"
                      width="200"
                    >
                  </a>
                </div>
                <div class="cart-item__details">
                  <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <div class="cart-item__bottom">
                    <div class="cart-item__quantity">
                      <button type="button" class="cart-item__qty-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
                      <input
                        class="cart-item__qty-input"
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        max="{{ item.variant.inventory_quantity }}"
                        data-index="{{ forloop.index }}"
                        aria-label="Quantity"
                      >
                      <button type="button" class="cart-item__qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
                    </div>
                    <p class="cart-item__price">{{ item.final_line_price | money }}</p>
                    <button
                      type="button"
                      class="cart-item__remove"
                      data-line="{{ forloop.index }}"
                      aria-label="Remove {{ item.title | escape }}"
                    >
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                        <path d="M2 4h12M6 4V2h4v2M5 4l1 10h4l1-10"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <div class="cart-page__summary">
            <div class="cart-page__totals">
              <div class="cart-page__subtotal-row">
                <span>Subtotal</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
              <p class="cart-page__shipping-note">Shipping and taxes calculated at checkout.</p>
            </div>
            <button type="submit" name="checkout" class="btn btn--primary btn--large btn--full">
              Proceed to Checkout
            </button>
            <a
              class="btn btn--whatsapp btn--full"
              href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ 'I would like to place an order from ' | append: shop.name | url_encode }}"
              target="_blank"
              rel="noopener"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Order via WhatsApp Instead
            </a>
            <a class="cart-page__continue" href="{{ routes.all_products_collection_url }}">Continue Shopping</a>
          </div>
        </div>
      {%- endform -%}
    {%- else -%}
      <div class="cart-page__empty">
        <div class="cart-page__empty-icon" aria-hidden="true">◇</div>
        <p class="cart-page__empty-title">Your cart is empty</p>
        <p class="cart-page__empty-sub">Begin your collection below.</p>
        <a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">Shop the Collection</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-cart"
}
{% endschema %}
