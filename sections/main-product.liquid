{%- assign current_variant = product.selected_or_first_available_variant -%}

<article class="product-page" id="product-{{ product.id }}" itemscope itemtype="https://schema.org/Product">
  <div class="product-page__gallery">
    <div class="product-page__gallery-main" id="product-gallery-main">
      {%- for media in product.media -%}
        <div class="product-page__media-item{% if forloop.first %} product-page__media-item--active{% endif %}" data-media-id="{{ media.id }}">
          {%- if media.media_type == 'video' -%}
            <video class="product-page__video" controls muted loop playsinline
              poster="{{ media.preview_image | image_url: width: 1000 }}">
              {%- for source in media.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- else -%}
            <img
              class="product-page__image"
              src="{{ media | image_url: width: 1000 }}"
              alt="{{ media.alt | default: product.title | escape }}"
              width="{{ media.width }}"
              height="{{ media.height }}"
              loading="{{ forloop.first | yesno: 'eager,lazy' }}"
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if product.media.size > 1 -%}
      <div class="product-page__thumbnails">
        {%- for media in product.media -%}
          <button class="product-page__thumb{% if forloop.first %} active{% endif %}" data-media-id="{{ media.id }}" aria-label="View image {{ forloop.index }}">
            <img src="{{ media | image_url: width: 120 }}" alt="{{ media.alt | escape }}" loading="lazy" width="120">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-page__info">
    {%- if product.vendor != blank -%}
      <p class="product-page__vendor" itemprop="brand">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="product-page__title" itemprop="name">{{ product.title }}</h1>

    <div class="product-page__price" id="product-price">
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <s class="product-page__compare-price">{{ current_variant.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="product-page__sale-price" itemprop="price" content="{{ current_variant.price | money_without_currency }}">
        {{ current_variant.price | money }}
      </span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="product-page__save-badge">
          Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
        </span>
      {%- endif -%}
    </div>

    {%- unless product.has_only_default_variant -%}
      {%- for option in product.options_with_values -%}
        <div class="product-page__option">
          <label class="product-page__option-label">{{ option.name }}</label>
          <div class="product-page__option-values">
            {%- for value in option.values -%}
              <button
                class="product-page__option-btn{% if option.selected_value == value %} active{% endif %}"
                data-option-position="{{ option.position }}"
                data-value="{{ value | escape }}"
              >
                {{ value | escape }}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endunless -%}

    <div class="product-page__actions">
      {%- form 'product', product, id: 'product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input type="hidden" name="id" id="product-variant-id" value="{{ current_variant.id }}">

        <button
          type="submit"
          class="btn btn--primary btn--large btn--full"
          id="add-to-cart"
          {%- unless current_variant.available -%}disabled{%- endunless -%}
        >
          {%- if current_variant.available -%}
            Add to Cart — {{ current_variant.price | money }}
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      {%- endform -%}

      <a
        class="btn btn--whatsapp btn--large btn--full"
        href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ 'I would like to order: ' | append: product.title | append: ' from ' | append: shop.url | append: product.url | url_encode }}"
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Order Privately via WhatsApp
      </a>
    </div>

    {%- if product.description != blank -%}
      <div class="product-page__description rte" itemprop="description">
        {{ product.description }}
      </div>
    {%- endif -%}

    {%- if product.tags.size > 0 -%}
      <div class="product-page__tags">
        {%- for tag in product.tags -%}
          <a class="product-page__tag" href="{{ routes.collections_url }}/all/{{ tag | handle }}">{{ tag }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</article>

<script type="application/json" id="product-variants-json">
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "class": "section-main-product"
}
{% endschema %}
