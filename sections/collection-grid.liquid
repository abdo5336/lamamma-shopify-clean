<section class="collection-grid" id="collection-grid-{{ section.id }}">
  <div class="container">
    <div class="section-header section-header--centered">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="collection-grid__items">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        <a
          class="collection-tile"
          href="{{ coll.url | default: block.settings.url | default: routes.collections_url }}"
          {{ block.shopify_attributes }}
        >
          <div class="collection-tile__media">
            {%- if block.settings.image != blank -%}
              <img
                class="collection-tile__image"
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | default: coll.title | escape }}"
                loading="lazy"
                width="600"
              >
            {%- elsif coll != blank and coll.image -%}
              <img
                class="collection-tile__image"
                src="{{ coll.image | image_url: width: 600 }}"
                alt="{{ coll.title | escape }}"
                loading="lazy"
                width="600"
              >
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'collection-tile__placeholder' }}
            {%- endif -%}
            <div class="collection-tile__overlay"></div>
          </div>
          <div class="collection-tile__info">
            {%- assign tile_icon = block.settings.icon -%}
            {%- if tile_icon != blank -%}
              <span class="collection-tile__icon">{{ tile_icon }}</span>
            {%- endif -%}
            <h3 class="collection-tile__title">{{ block.settings.title | default: coll.title | escape }}</h3>
            {%- if coll != blank -%}
              <span class="collection-tile__count">{{ coll.products_count }} items</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Catalogue"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon character",
          "default": "✦"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Override URL"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        { "type": "collection_tile", "settings": { "title": "Signature Bundles", "icon": "◈" } },
        { "type": "collection_tile", "settings": { "title": "Rolling Trays", "icon": "▭" } },
        { "type": "collection_tile", "settings": { "title": "Grinders", "icon": "⊙" } },
        { "type": "collection_tile", "settings": { "title": "Lighters", "icon": "◇" } },
        { "type": "collection_tile", "settings": { "title": "Pouches & Storage", "icon": "◫" } },
        { "type": "collection_tile", "settings": { "title": "Accessories", "icon": "✦" } }
      ]
    }
  ]
}
{% endschema %}
